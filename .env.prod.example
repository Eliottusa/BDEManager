# =====================================================================
#  BDE Manager - Configuration de PRODUCTION (fichier unique)
# ---------------------------------------------------------------------
#  1. Copier ce fichier :   cp .env.prod.example .env.prod
#  2. Remplir TOUTES les valeurs « CHANGE_ME »
#  3. Lancer :
#       docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
#
#  ⚠️  Les variables NEXT_PUBLIC_* sont figées au BUILD du front.
# =====================================================================

# ─── Domaines & TLS (Caddy) ──────────────────────────────────────────
# Les enregistrements DNS A/AAAA de ces domaines doivent pointer vers le VPS.
APP_DOMAIN=app.tondomaine.fr
API_DOMAIN=api.tondomaine.fr
# Email utilisé par Let's Encrypt pour les certificats
CADDY_EMAIL=toi@tondomaine.fr

# ─── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_USER=bde
POSTGRES_PASSWORD=CHANGE_ME_mot_de_passe_postgres_fort
POSTGRES_DB=bdemanager

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_mot_de_passe_redis_fort
REDIS_TTL=86400

# ─── JWT (générer : openssl rand -base64 48) ─────────────────────────
JWT_SECRET=CHANGE_ME_secret_jwt_32_caracteres_minimum
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_secret_refresh_32_caracteres_minimum
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email SMTP (production - fournisseur réel) ──────────────────────
# Exemple Brevo : smtp-relay.brevo.com:587 - Mailtrap, Gmail app-password, etc.
SMTP_HOST=smtp.tonfournisseur.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM="BDE Manager <noreply@tondomaine.fr>"

# ─── Stripe ──────────────────────────────────────────────────────────
# Clé secrète backend (sk_live_... en prod)
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
# Secret de signature du webhook (configurer l'endpoint dans le dashboard Stripe :
#   https://api.tondomaine.fr/api/v1/payments/webhooks/stripe )
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ─── Géolocalisation (API publique, pas de clé) ──────────────────────
GEO_API_URL=https://api-adresse.data.gouv.fr

# ─── Frontend (côté serveur API : CORS) ──────────────────────────────
# Doit correspondre EXACTEMENT à l'URL publique du front (sinon CORS bloqué)
FRONTEND_URL=https://app.tondomaine.fr

# ─── Frontend Next.js - variables PUBLIQUES (build-time) ─────────────
# Inlinées dans le bundle navigateur. Doivent pointer vers l'API publique.
NEXT_PUBLIC_API_URL=https://api.tondomaine.fr/api/v1
NEXT_PUBLIC_WS_URL=https://api.tondomaine.fr
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
NEXT_PUBLIC_MOCK_AUTH=false

# ─── Initialisation BDD ──────────────────────────────────────────────
# true  = seed automatique au tout premier démarrage (base vide uniquement)
# false = aucune donnée de démo insérée
RUN_SEED=true
