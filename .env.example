# ─── Application ────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=bde
POSTGRES_PASSWORD=secret
POSTGRES_DB=bdemanager
DATABASE_URL="postgresql://bde:secret@localhost:5432/bdemanager?schema=public"

# ─── Redis ───────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=secret
REDIS_TTL=86400

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_32_chars_min
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_32_chars_min
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email (SMTP) ────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="BDE Manager <noreply@bde-manager.fr>"

# ─── Stripe ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Next.js (public vars) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=http://localhost:3001

# ─── Données gouv (address autocomplete) ────────────────────────
# Base URL: https://api-adresse.data.gouv.fr — no key required
GEO_API_URL=https://api-adresse.data.gouv.fr
